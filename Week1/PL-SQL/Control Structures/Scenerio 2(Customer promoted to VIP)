Customer Promoted to VIP based on available balance.

DECLARE
BEGIN
    FOR cust IN (
        SELECT CustomerID, Balance
        FROM Customers
    )
    LOOP
        IF cust.Balance > 10000 THEN
            UPDATE Customers
            SET IsVIP = 'TRUE'
            WHERE CustomerID = cust.CustomerID;

            DBMS_OUTPUT.PUT_LINE('Customer '
                                 || cust.CustomerID
                                 || ' promoted to VIP');
        END IF;
    END LOOP;

    COMMIT;
END;
/


